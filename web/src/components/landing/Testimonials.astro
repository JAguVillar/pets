---
// Mock data por ahora — no hay tabla de testimonios. Cuando los agreguemos,
// se reemplaza por un query a Supabase.
const items = [
  {
    quote:
      "Encontramos a Lola hace seis meses. Vino con un montón de miedo y hoy es la dueña del sillón. Gracias a todo el equipo del refugio.",
    name: "Camila R.",
    role: "Adoptante · CABA",
  },
  {
    quote:
      "Reporté a Toto en Pets y a las cuatro horas alguien lo había visto. Lo recuperamos esa misma noche. Increíble la red de gente.",
    name: "Martín G.",
    role: "Tutor · Vicente López",
  },
  {
    quote:
      "Como refugio pequeño, nos da visibilidad real. Salimos del Instagram y llegamos a familias que antes no nos veían.",
    name: "Refugio Patitas",
    role: "Refugio verificado",
  },
];
---

<section class="max-w-7xl mx-auto px-5 sm:px-10 lg:px-16 py-16 lg:py-20">
  <div
    class="font-bold text-[13px] uppercase tracking-[.1em] text-emerald-600 mb-2.5"
  >
    Historias reales
  </div>
  <h2
    class="font-extrabold text-2xl sm:text-3xl lg:text-[32px] leading-tight text-slate-900 tracking-tight mb-8"
  >
    Las que ya encontraron lo que buscaban.
  </h2>

  <div class="grid md:grid-cols-3 gap-5">
    {items.map((t) => (
      <article
        class="bg-slate-50 border border-slate-200/70 rounded-[22px] p-7"
      >
        <div class="font-extrabold text-[40px] leading-none text-emerald-500 mb-1.5">
          “
        </div>
        <p class="font-medium text-base leading-relaxed text-slate-700 mb-5">
          {t.quote}
        </p>
        <div class="flex items-center gap-3">
          <span
            class="w-11 h-11 rounded-full bg-slate-200 inline-flex items-center justify-center text-slate-500"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
              ></path>
              <circle cx="9" cy="7" r="4"></circle>
            </svg>
          </span>
          <div>
            <div class="font-bold text-sm text-slate-900">{t.name}</div>
            <div class="font-medium text-xs text-slate-400">{t.role}</div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
