---
import { supabase } from "../../lib/supabase.js";
import { ROUTES } from "../../lib/config.js";

let lost = [];
let fetchError = null;
try {
  const { data, error } = await supabase
    .from("lost_pets")
    .select(
      `
        id,
        name,
        images,
        last_seen_date,
        last_seen_location,
        reward,
        breed:breed_id (name, species:species_id (name, icon)),
        status:status_id!inner (slug, name)
      `,
    )
    .eq("status.slug", "lost")
    .order("created_at", { ascending: false })
    .limit(4);
  if (error) throw error;
  lost = data ?? [];
} catch (e) {
  fetchError = e;
  console.warn("[landing/LostBand] supabase fetch failed:", e.message);
}

function daysAgo(iso) {
  if (!iso) return null;
  const ms = Date.now() - new Date(iso).getTime();
  const d = Math.max(0, Math.floor(ms / (1000 * 60 * 60 * 24)));
  if (d === 0) return "hoy";
  if (d === 1) return "1 día";
  if (d < 30) return `${d} días`;
  const m = Math.floor(d / 30);
  return m === 1 ? "1 mes" : `${m} meses`;
}

function moneyAR(v) {
  if (v == null) return null;
  return `$ ${new Intl.NumberFormat("es-AR").format(v)}`;
}
---

<section
  id="perdidos"
  class="bg-orange-50 border-y border-orange-200"
>
  <div class="max-w-7xl mx-auto px-5 sm:px-10 lg:px-16 py-16 lg:py-20">
    <div class="flex items-end justify-between gap-4 mb-7 flex-wrap">
      <div>
        <div
          class="inline-flex items-center gap-2 font-bold text-[13px] uppercase tracking-[.1em] text-orange-600 mb-2.5"
        >
          <span
            class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_0_4px_rgba(239,68,68,.18)]"
          ></span>
          Perdidas recientes
        </div>
        <h2
          class="font-extrabold text-2xl sm:text-3xl lg:text-[32px] leading-tight tracking-tight text-orange-900 mb-2"
        >
          Las están buscando ahora.
        </h2>
        <p class="text-[15px] text-orange-800/80 m-0">
          Si la viste, un mensaje puede cambiar todo. Reportar es gratis.
        </p>
      </div>
      <a
        href={ROUTES.adminLostNew}
        class="font-bold text-sm text-orange-600 hover:text-orange-700 inline-flex items-center gap-1.5"
      >
        Ver todos los reportes
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    {lost.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {lost.map((l) => (
          <a
            href={ROUTES.adminLostNew}
            class="group bg-white border border-orange-200 rounded-[20px] overflow-hidden transition-all hover:-translate-y-1 hover:shadow-[0_16px_32px_rgba(124,45,18,0.12)]"
          >
            <div class="aspect-[4/3] relative bg-stone-100">
              {l.images?.[0] ? (
                <img
                  src={l.images[0]}
                  alt={l.name || "Mascota perdida"}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-stone-300">
                  <svg
                    width="48"
                    height="48"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <circle cx="5.5" cy="10.5" r="2.2"></circle>
                    <circle cx="9.5" cy="6.5" r="2.2"></circle>
                    <circle cx="14.5" cy="6.5" r="2.2"></circle>
                    <circle cx="18.5" cy="10.5" r="2.2"></circle>
                    <path
                      d="M12 12c-2.5 0-4.5 2.2-4.5 4.4 0 1.8 1.6 2.6 4.5 2.6s4.5-.8 4.5-2.6C16.5 14.2 14.5 12 12 12Z"
                    ></path>
                  </svg>
                </div>
              )}
              <span
                class="absolute top-3 left-3 font-extrabold text-[10px] tracking-[.08em] text-white bg-red-500 px-2.5 py-1.5 rounded-full"
              >
                PERDIDA
              </span>
            </div>
            <div class="px-4 pt-4 pb-5">
              <div class="font-bold text-lg text-slate-900 mb-2.5">
                {l.name || "Sin nombre"}
              </div>
              {daysAgo(l.last_seen_date) && (
                <div
                  class="flex items-center gap-1.5 font-semibold text-[13px] text-orange-700 mb-1.5"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                    <path d="M3 10h18M8 2v4M16 2v4"></path>
                  </svg>
                  Última vez: hace {daysAgo(l.last_seen_date)}
                </div>
              )}
              {l.last_seen_location && (
                <div
                  class="flex items-center gap-1.5 font-medium text-[13px] text-stone-500 mb-3.5"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#a8a29e"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path
                      d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                    ></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                  {l.last_seen_location}
                </div>
              )}
              <div
                class="flex items-center justify-between border-t border-stone-100 pt-3"
              >
                {l.reward != null ? (
                  <span
                    class="inline-flex items-center gap-1.5 font-bold text-[13px] text-green-600"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <rect x="3" y="8" width="18" height="4" rx="1"></rect>
                      <path
                        d="M12 8v13M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"
                      ></path>
                    </svg>
                    Recompensa {moneyAR(l.reward)}
                  </span>
                ) : (
                  <span></span>
                )}
                <span class="font-bold text-[13px] text-slate-900">
                  La vi →
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div
        class="bg-white border border-dashed border-orange-200 rounded-[20px] p-12 text-center"
      >
        <div class="font-bold text-lg text-orange-900 mb-2">
          {fetchError
            ? "No pudimos cargar los reportes"
            : "Por ahora no hay reportes activos"}
        </div>
        <p class="text-sm text-orange-800/70 m-0">
          {fetchError
            ? "Probá refrescar la página en un momento."
            : "Si perdiste o encontraste una mascota, sumá tu reporte."}
        </p>
      </div>
    )}
  </div>
</section>
