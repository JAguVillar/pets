SUPABASE_URL=
SUPABASE_KEY=

# DB password — para correr `pnpm exec supabase db push` (migrations)
SUPABASE_DB_PASSWORD=

# Service role key — solo para scripts admin como el seed (.claude/skills/seed-db).
# Sacalo de Supabase Dashboard → Settings → API → "service_role secret".
# NUNCA exponer al cliente ni commitearlo.
SUPABASE_SERVICE_ROLE_KEY=
