---
import { supabase } from "../../lib/supabase.js";

// Build-time fetch — si llegamos a SSR después, este mismo código corre por request.
let pets = [];
let fetchError = null;
try {
  const { data, error } = await supabase
    .from("animals_for_adoption")
    .select(
      `
        id,
        name,
        age_years,
        images,
        breed:breed_id (name, species:species_id (name, icon)),
        size:size_id (name),
        sex:sex_id (name),
        status:status_id!inner (slug, name),
        organization:organization_id (name)
      `,
    )
    .eq("status.slug", "available")
    .order("created_at", { ascending: false })
    .limit(8);
  if (error) throw error;
  pets = data ?? [];
} catch (e) {
  fetchError = e;
  console.warn("[landing/AdoptionGrid] supabase fetch failed:", e.message);
}

function ageLabel(years) {
  if (years == null) return null;
  if (years < 1) return "Cachorro";
  return `${years} ${years === 1 ? "año" : "años"}`;
}
---

<section
  id="adopcion"
  class="max-w-7xl mx-auto px-5 sm:px-10 lg:px-16 pb-16 lg:pb-20"
>
  <div class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <div
        class="font-bold text-[13px] uppercase tracking-[.1em] text-emerald-600 mb-2"
      >
        En adopción ahora
      </div>
      <h2
        class="font-extrabold text-2xl sm:text-3xl lg:text-[32px] leading-tight text-slate-900 tracking-tight m-0"
      >
        Esperando una familia.
      </h2>
    </div>
    <a
      href="#adopcion"
      class="font-bold text-sm text-emerald-600 hover:text-emerald-700 inline-flex items-center gap-1.5"
    >
      Ver todas
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  {pets.length > 0 ? (
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {pets.map((p) => (
        <a
          href="#adopcion"
          class="group bg-white border border-slate-200/70 rounded-[20px] overflow-hidden transition-all hover:-translate-y-1 hover:shadow-[0_16px_32px_rgba(15,23,42,0.1)]"
        >
          <div class="aspect-square relative bg-slate-100">
            {p.images?.[0] ? (
              <img
                src={p.images[0]}
                alt={p.name}
                loading="lazy"
                width="320"
                height="320"
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-slate-300">
                <svg
                  width="48"
                  height="48"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <circle cx="5.5" cy="10.5" r="2.2"></circle>
                  <circle cx="9.5" cy="6.5" r="2.2"></circle>
                  <circle cx="14.5" cy="6.5" r="2.2"></circle>
                  <circle cx="18.5" cy="10.5" r="2.2"></circle>
                  <path
                    d="M12 12c-2.5 0-4.5 2.2-4.5 4.4 0 1.8 1.6 2.6 4.5 2.6s4.5-.8 4.5-2.6C16.5 14.2 14.5 12 12 12Z"
                  ></path>
                </svg>
              </div>
            )}
            <span
              class="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/90 inline-flex items-center justify-center text-slate-500 hover:text-emerald-500 transition-colors"
              aria-label="Guardar"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.49 4.04 3 5.5l7 7Z"
                ></path>
              </svg>
            </span>
          </div>
          <div class="px-4 pt-4 pb-5">
            <div class="font-bold text-lg text-slate-900 mb-2.5">{p.name}</div>
            <div class="flex flex-wrap gap-1.5 mb-3">
              {p.breed?.species?.name && (
                <span class="font-semibold text-[11px] text-slate-600 bg-slate-100 px-2 py-1 rounded-full">
                  {p.breed.species.name}
                </span>
              )}
              {ageLabel(p.age_years) && (
                <span class="font-semibold text-[11px] text-slate-600 bg-slate-100 px-2 py-1 rounded-full">
                  {ageLabel(p.age_years)}
                </span>
              )}
              {p.size?.name && (
                <span class="font-semibold text-[11px] text-slate-600 bg-slate-100 px-2 py-1 rounded-full">
                  {p.size.name}
                </span>
              )}
            </div>
            <div
              class="flex items-center gap-1.5 font-medium text-xs text-slate-400"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                ></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              {p.organization?.name ?? "Particular"}
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div
      class="bg-slate-50 border border-dashed border-slate-200 rounded-[20px] p-12 text-center"
    >
      <div class="font-bold text-lg text-slate-900 mb-2">
        Pronto sumamos publicaciones
      </div>
      <p class="text-sm text-slate-500 m-0">
        {fetchError
          ? "Tuvimos un problema cargando los datos. Probá refrescar."
          : "Las primeras mascotas en adopción van a aparecer acá."}
      </p>
    </div>
  )}
</section>
