---
import { supabase } from "../../lib/supabase.js";

let shelters = [];
try {
  const { data, error } = await supabase
    .from("organizations")
    .select("name")
    .eq("verified", true)
    .order("name", { ascending: true })
    .limit(6);
  if (error) throw error;
  shelters = data ?? [];
} catch (e) {
  console.warn("[landing/Shelters] supabase fetch failed:", e.message);
}
---

{shelters.length > 0 && (
  <section
    id="refugios"
    class="max-w-7xl mx-auto px-5 sm:px-10 lg:px-16 pb-16 lg:pb-20"
  >
    <div
      class="bg-slate-50 border border-slate-200/70 rounded-3xl px-8 py-9 sm:px-10 sm:py-10"
    >
      <div
        class="font-semibold text-[13px] text-slate-400 text-center mb-6"
      >
        Refugios verificados que ya publican en Pets
      </div>
      <div
        class="flex items-center justify-center gap-6 sm:gap-10 lg:gap-12 flex-wrap"
      >
        {shelters.map((s) => (
          <span
            class="inline-flex items-center gap-2 font-extrabold text-base sm:text-lg text-slate-400 tracking-tight"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#cbd5e1"
              stroke-width="2.2"
              aria-hidden="true"
            >
              <circle cx="5.5" cy="10.5" r="2"></circle>
              <circle cx="9.5" cy="6.5" r="2"></circle>
              <circle cx="14.5" cy="6.5" r="2"></circle>
              <circle cx="18.5" cy="10.5" r="2"></circle>
              <path
                d="M12 12c-2.2 0-4 2-4 4 0 1.6 1.4 2.3 4 2.3s4-.7 4-2.3c0-2-1.8-4-4-4Z"
              ></path>
            </svg>
            {s.name}
          </span>
        ))}
      </div>
    </div>
  </section>
)}
